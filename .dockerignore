# ============================================
# Docker Build Ignore File
# ============================================
# Reduces build context size from ~1.5GB to ~10MB

# Dependencies (installed in container)
node_modules
.pnpm-store

# Build outputs
.next
.next-admin
dist
build
out
coverage
.nyc_output

# Environment files (secrets - passed at runtime)
.env
.env.*
!.env.development.example
!.env.production.example

# Git
.git
.gitignore

# IDE / editor tools
.vscode
.idea
.qodo
*.swp
*.swo

# Documentation (not needed in container)
docs
*.md
!README.md

# SSL certificates (mounted at runtime)
ssl

# Database backups
*.sql
!prisma/migrations/**/*.sql

# Backup / temp files
*.bak
*.tmp
*.temp
_archive_

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server.log

# Nginx configs (mounted at runtime)
nginx

# Scripts (not needed in container)
scripts

# Docker files (not needed in build context)
docker-compose*.yml
Dockerfile*

# Test files
**/*.test.ts
**/*.spec.ts
**/__tests__
vitest*.ts

# Misc
.turbo
.vercel
.sentryclirc
*.tsbuildinfo

# Accidental psql output files
ql *
