// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// Enums
// ===========================================

enum PlanType {
  FREE
  STARTER     // $9/mo tier
  PRO
  BUSINESS    // $79/mo tier
  ENTERPRISE  // Custom pricing
}

enum UserRole {
  SUPER_ADMIN   // Full platform control
  ADMIN         // Platform administrator
  DEVELOPER     // Marketplace developer
  SUPPORT       // Customer support (future)
  MEMBER        // Standard user (default)
}

enum OrgRole {
  ORG_OWNER     // Organization owner
  ORG_ADMIN     // Can manage org users/settings
  DEPT_MANAGER  // Manages their department
  ORG_MEMBER    // Regular org member
}

enum MembershipStatus {
  INVITED       // Pending invite
  ACTIVE        // Full member
  SUSPENDED     // Temporarily disabled
}

enum InviteStatus {
  PENDING       // Waiting for response
  ACCEPTED      // Invite was accepted
  DECLINED      // Invite was declined by recipient
  EXPIRED       // Invite has expired (computed, not stored)
}

enum DatabaseType {
  SHARED        // Uses default shared database (Free/Starter/Pro/Business)
  DEDICATED     // Has own database instance (Enterprise)
}

enum GatewayType {
  TELEGRAM_BOT    // Telegram Bot API (uses botToken)
  DISCORD_BOT     // Discord Bot API (uses botToken + applicationId)
  SLACK_BOT       // Slack Bot API (uses botToken + signingSecret)
  WHATSAPP_BOT    // WhatsApp Cloud API (uses accessToken + phoneNumberId)
  // TELEGRAM_ACCOUNT - MTProto user accounts (V2 - requires phone auth flow)
}

enum GatewayStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}

enum ExecutionMode {
  SERVERLESS    // Traditional serverless execution with per-execution limits
  WORKSPACE     // Docker-based workspace with persistent resources
}

enum OrgPlan {
  ORG_FREE        // Free tier - limited features
  ORG_STARTER     // $49/mo - 5 seats, 5 gateways
  ORG_GROWTH      // $99/mo - 15 seats, 15 gateways
  ORG_PRO         // $199/mo - 40 seats, 50 gateways
  ORG_BUSINESS    // $399/mo - 100 seats, 150 gateways
  ORG_ENTERPRISE  // Custom - unlimited
}

enum AllocationMode {
  UNLIMITED     // Use from pool freely (no limit set)
  SOFT_CAP      // Warning at limit, can request more
  HARD_CAP      // Blocked at limit
  RESERVED      // Guaranteed allocation, others can't use
}

// ===========================================
// Workspace Container Status (Phase 13: Workspace)
// ===========================================
enum ContainerStatus {
  CREATING      // Docker image being pulled / container being created
  STARTING      // Container starting up, bridge agent initializing
  RUNNING       // Container healthy, bridge agent connected
  STOPPING      // Graceful shutdown in progress
  STOPPED       // Container exited, data preserved
  ERROR         // Container crashed or health check failed
  DESTROYED     // Container removed (data may be preserved in volume)
}

enum WorkspaceFileType {
  FILE
  DIRECTORY
}

enum WorkspaceOwnerType {
  PERSONAL      // User's personal workspace
  ORGANIZATION  // Organization shared workspace
}

enum PluginAuthorType {
  SYSTEM    // Built-in platform plugins
  USER      // Human-created custom plugins
  AI        // AI-agent created (future)
}

// ===========================================
// User Model (Phase 1: Authentication)
// ===========================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  emailVerified DateTime? @map("email_verified")
  image         String?

  // Role System (for admin, developer, support)
  role              UserRole  @default(MEMBER)
  
  // Security (for future 2FA, account lockout)
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  lastPasswordChange DateTime? @map("last_password_change")
  
  // Soft Delete Support
  deletedAt         DateTime? @map("deleted_at")

  // Subscription (personal workspace)
  plan             PlanType      @default(FREE)
  executionMode    ExecutionMode @default(SERVERLESS) @map("execution_mode")
  stripeCustomerId String?       @unique @map("stripe_customer_id")
  
  // Workspace Add-ons (array of addon tier strings: MICRO, SMALL, MEDIUM, LARGE, XLARGE)
  workspaceAddons    String[]  @default([]) @map("workspace_addons")
  
  // Computed workspace resources (updated when plan/addons change)
  workspaceRamMb     Int?      @map("workspace_ram_mb")
  workspaceCpuCores  Float?    @map("workspace_cpu_cores")
  workspaceStorageMb Int?      @map("workspace_storage_mb")

  // AI Routing Preference (quality=best models first, balanced=default, cost=cheapest first)
  aiRoutingPreference  String  @default("balanced") @map("ai_routing_preference")

  // Status
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  gateways            Gateway[]
  creditWallet        CreditWallet?
  userPlugins         UserPlugin[]
  workflows           Workflow[]
  aiUsage             AIUsage[]
  memberships         Membership[]
  invitedMemberships  Membership[] @relation("InvitedMemberships")
  departmentMembers   DepartmentMember[]
  usageHistory        UsageHistory[]
  subscription        Subscription?
  memberAllocations   MemberAllocation[]
  deptAllocsSetBy     DeptAllocation[]   @relation("DeptAllocSetBy")
  memberAllocsSetBy   MemberAllocation[] @relation("MemberAllocSetBy")
  orgInvitesSent      OrgInvite[]

  // Support relations (Phase 7)
  supportTickets       SupportTicket[]  @relation("UserTickets")
  assignedTickets      SupportTicket[]  @relation("AssignedTickets")
  ticketMessages       TicketMessage[]  @relation("TicketMessageSender")
  kbArticles           KBArticle[]      @relation("KBArticleAuthor")

  // Workspace relations (Phase 13)
  workspaceContainers  WorkspaceContainer[]
  allowedDomains       WorkspaceAllowedDomain[]

  // AI Agent relations
  agentSessions        AgentSession[]

  // Admin domain blacklist
  adminBlockedDomains  AdminBlockedDomain[] @relation("AdminBlockedDomains")

  @@index([email])
  @@index([stripeCustomerId])
  @@index([deletedAt])
  @@index([role])
  @@map("users")
}

// ===========================================
// Session Model (Phase 1: Authentication)
// ===========================================
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ===========================================
// Password Reset Token (Phase 1: Authentication)
// ===========================================
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ===========================================
// Subscription Model (Phase 5: Billing)
// Stripe subscription for User OR Organization
// ===========================================
model Subscription {
  id                   String    @id @default(cuid())
  
  // Owner reference (exactly one of these)
  userId               String?   @unique @map("user_id")
  organizationId       String?   @unique @map("organization_id")
  
  // Stripe fields
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  stripeStatus         String?   @map("stripe_status") // 'active', 'past_due', 'canceled', etc.
  
  // Plan info - String to support both user (FREE, STARTER, etc.) and org (ORG_FREE, ORG_STARTER, etc.) plans
  plan                 String    @default("FREE")
  
  // Billing period
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  
  // Timestamps
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user                 User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([stripeSubscriptionId])
  @@index([stripeStatus])
  @@map("subscriptions")
}

// ===========================================
// Organization Model (Phase 4: Organization)
// ===========================================
model Organization {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  
  // Billing (linked in Phase 5)
  plan             OrgPlan      @default(ORG_FREE) @map("org_plan")
  stripeCustomerId String?      @unique @map("stripe_customer_id")
  
  // Seat management
  maxSeats         Int          @default(5) @map("max_seats")
  usedSeats        Int          @default(0) @map("used_seats")
  
  // Shared workspace pool resources (from org plan)
  workspacePoolRamMb        Int          @default(4096) @map("workspace_pool_ram_mb")
  workspacePoolCpuCores     Float        @default(2) @map("workspace_pool_cpu_cores")
  workspacePoolStorageMb    Int          @default(20480) @map("workspace_pool_storage_mb")
  
  // Database Isolation (Future-Ready)
  // See Phase 1.5 for architecture details
  databaseType     DatabaseType @default(SHARED)
  databaseUrl      String?      @map("database_url")     // Encrypted if dedicated
  databaseRegion   String?      @map("database_region")  // 'us-east', 'eu-west'
  
  // Status
  isActive         Boolean      @default(true) @map("is_active")
  
  // Timestamps
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  
  // Relations
  memberships      Membership[]
  departments      Department[]
  gateways         Gateway[]
  userPlugins      UserPlugin[]
  workflows        Workflow[]
  usageHistory     UsageHistory[]
  alertConfig      AlertConfig?
  alertHistory     AlertHistory[]
  subscription     Subscription?
  orgInvites       OrgInvite[]
  creditWallet     CreditWallet?

  // Workspace relations (Phase 13)
  workspaceContainers  WorkspaceContainer[]
  
  @@index([slug])
  @@index([databaseType])
  @@index([isActive])
  @@map("organizations")
}

// ===========================================
// Membership Model (Phase 4: Organization)
// User ↔ Organization relationship with role
// ===========================================
model Membership {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  organizationId String           @map("organization_id")
  
  // Role in this organization
  role           OrgRole          @default(ORG_MEMBER)
  
  // Status
  status         MembershipStatus @default(INVITED)
  
  // Invite tracking
  invitedBy      String?          @map("invited_by")
  invitedAt      DateTime         @default(now()) @map("invited_at")
  joinedAt       DateTime?        @map("joined_at")
  
  // Timestamps
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  
  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User?            @relation("InvitedMemberships", fields: [invitedBy], references: [id])
  departmentMembers DepartmentMember[]
  
  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("memberships")
}

// ===========================================
// OrgInvite Model (Phase 4: Organization)
// Pending invites for users who haven't registered yet
// ===========================================
model OrgInvite {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  
  // Invite target (email, not a user yet)
  email          String
  role           OrgRole      @default(ORG_MEMBER)
  
  // Secure invite token
  token          String       @unique
  
  // Invite tracking
  invitedBy      String       @map("invited_by")
  expiresAt      DateTime     @map("expires_at")
  resendCount    Int          @default(0) @map("resend_count")
  lastResentAt   DateTime?    @map("last_resent_at")
  
  // Status
  status         InviteStatus @default(PENDING)
  usedAt         DateTime?    @map("used_at")
  declinedAt     DateTime?    @map("declined_at")
  
  // Timestamps
  createdAt      DateTime     @default(now()) @map("created_at")
  
  // Relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter        User         @relation(fields: [invitedBy], references: [id])
  
  @@unique([organizationId, email])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("org_invites")
}

// ===========================================
// Department Model (Phase 4: Organization)
// Organization hierarchy for resource quotas
// ===========================================
model Department {
  id               String       @id @default(cuid())
  organizationId   String       @map("organization_id")
  name             String
  description      String?
  
  // NOTE: Legacy quota fields (maxWorkflows, maxPlugins, maxWorkflowRuns, maxStorage)
  // have been migrated to DeptAllocation table. Use allocationService for quotas.
  
  // Status
  isActive         Boolean      @default(true) @map("is_active")
  
  // Timestamps
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  
  // Relations
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members          DepartmentMember[]
  workflows        Workflow[]
  usageHistory     UsageHistory[]
  deptAllocation   DeptAllocation?
  memberAllocations MemberAllocation[]
  
  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isActive])
  @@map("departments")
}

// ===========================================
// Department Member (Phase 4: Organization)
// User ↔ Department relationship with role
// ===========================================
model DepartmentMember {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  departmentId   String           @map("department_id")
  membershipId   String           @map("membership_id")
  
  // Role in this department
  role           DepartmentRole   @default(MEMBER)
  
  // NOTE: Legacy quota fields (maxWorkflows, maxPlugins) have been migrated
  // to MemberAllocation table. Use allocationService for member quotas.
  
  // Timestamps
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  
  // Relations
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  department     Department       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  membership     Membership       @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  
  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@map("department_members")
}

enum DepartmentRole {
  MANAGER    // Can manage dept workflows, set employee limits
  MEMBER     // Can use dept workflows, create personal workflows
}

enum PeriodType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

// ===========================================
// Department Allocation (Phase 6.8: Quota Management)
// Admin allocates org pool resources to departments
// ===========================================
model DeptAllocation {
  id              String         @id @default(cuid())
  departmentId    String         @unique @map("department_id")
  
  // Allocated from org pool
  maxGateways     Int?           @map("max_gateways")
  maxWorkflows    Int?           @map("max_workflows")
  maxPlugins      Int?           @map("max_plugins")
  creditBudget    Int?           @map("credit_budget")      // credits per month
  
  // Credit usage tracking (resets monthly)
  creditUsed      Int            @default(0) @map("credit_used")
  creditResetAt   DateTime?      @map("credit_reset_at")
  
  // Workspace allocation
  maxRamMb        Int?           @map("max_ram_mb")
  maxCpuCores     Float?         @map("max_cpu_cores")
  maxStorageMb    Int?           @map("max_storage_mb")
  
  allocMode       AllocationMode @default(SOFT_CAP) @map("alloc_mode")
  
  // Timestamps
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  setById         String         @map("set_by_id")
  
  // Relations
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  setBy           User           @relation("DeptAllocSetBy", fields: [setById], references: [id])
  
  @@map("dept_allocations")
}

// ===========================================
// Member Allocation (Phase 6.8: Quota Management)
// Manager allocates dept resources to members
// ===========================================
model MemberAllocation {
  id              String         @id @default(cuid())
  userId          String         @map("user_id")
  departmentId    String         @map("department_id")
  
  // Allocated from department pool
  maxGateways     Int?           @map("max_gateways")
  maxWorkflows    Int?           @map("max_workflows")
  creditBudget    Int?           @map("credit_budget")
  
  // Credit usage tracking (resets monthly)
  creditUsed      Int            @default(0) @map("credit_used")
  creditResetAt   DateTime?      @map("credit_reset_at")
  
  maxRamMb        Int?           @map("max_ram_mb")
  maxCpuCores     Float?         @map("max_cpu_cores")
  maxStorageMb    Int?           @map("max_storage_mb")
  
  allocMode       AllocationMode @default(SOFT_CAP) @map("alloc_mode")
  
  // Timestamps
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  setById         String         @map("set_by_id")
  
  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  department      Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  setBy           User           @relation("MemberAllocSetBy", fields: [setById], references: [id])
  
  @@unique([userId, departmentId])
  @@index([departmentId])
  @@map("member_allocations")
}

// ===========================================
// Usage History (Phase 4: Organization Quotas)
// Historical tracking for monitoring dashboard
// ===========================================
model UsageHistory {
  id               String       @id @default(cuid())
  
  // Owner reference (one of these)
  organizationId   String?      @map("organization_id")
  departmentId     String?      @map("department_id")
  userId           String?      @map("user_id")
  
  // Time bucket
  periodStart      DateTime     @map("period_start")
  periodType       PeriodType   @default(DAILY) @map("period_type")
  
  // Metrics
  requests         Int          @default(0) @map("requests")  // HTTP request count (monitoring)
  workflowRuns     Int          @default(0) @map("workflow_runs")  // Billing metric
  pluginExecutions Int          @default(0) @map("plugin_executions")
  storageUsed      Int          @default(0) @map("storage_used")    // MB at period end
  errors           Int          @default(0)
  
  // Cost tracking (for enterprise)
  estimatedCost    Decimal?     @map("estimated_cost") @db.Decimal(10, 2)
  
  // Timestamps
  createdAt        DateTime     @default(now()) @map("created_at")
  
  // Relations
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department       Department?   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user             User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([organizationId, periodStart, periodType])
  @@unique([departmentId, periodStart, periodType])
  @@unique([userId, periodStart, periodType])
  @@index([periodStart])
  @@index([organizationId])
  @@index([departmentId])
  @@index([userId])
  @@map("usage_history")
}

// ===========================================
// Alert Config (Phase 4: Resource Monitoring)
// Configuration for resource alerts per organization
// ===========================================
model AlertConfig {
  id                      String   @id @default(cuid())
  organizationId          String   @unique @map("organization_id")
  
  // Threshold settings
  quotaWarningThreshold   Int      @default(80) @map("quota_warning_threshold")
  quotaCriticalThreshold  Int      @default(95) @map("quota_critical_threshold")
  errorRateThreshold      Int      @default(10) @map("error_rate_threshold")
  consecutiveFailures     Int      @default(3) @map("consecutive_failures")
  
  // Cost thresholds (enterprise)
  dailyCostThreshold      Int?     @map("daily_cost_threshold")
  monthlyCostThreshold    Int?     @map("monthly_cost_threshold")
  
  // Notification channels (JSON)
  channels                Json     @default("{\"email\": true}")
  
  // Status
  enabled                 Boolean  @default(true)
  
  // Timestamps
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  
  // Relations
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@map("alert_configs")
}

// ===========================================
// Alert History (Phase 4: Resource Monitoring)
// Historical log of alerts sent
// ===========================================
model AlertHistory {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  
  // Alert details
  type             String    // AlertType enum value
  severity         String    // AlertSeverity enum value
  title            String
  message          String    @db.Text
  
  // Resource details (optional)
  resource         String?
  currentValue     Int?      @map("current_value")
  limitValue       Int?      @map("limit_value")
  percentage       Int?
  
  // Metadata (JSON)
  metadata         String?   @db.Text
  
  // Acknowledgement
  acknowledged     Boolean   @default(false)
  acknowledgedBy   String?   @map("acknowledged_by")
  acknowledgedAt   DateTime? @map("acknowledged_at")
  
  // Resolution
  resolvedAt       DateTime? @map("resolved_at")
  
  // Timestamps
  createdAt        DateTime  @default(now()) @map("created_at")
  
  // Relations
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([type])
  @@index([severity])
  @@index([acknowledged])
  @@index([createdAt])
  @@map("alert_history")
}

// ===========================================
// Gateway Model (Phase 2: Gateway System)
// ===========================================
model Gateway {
  id     String @id @default(cuid())
  userId String @map("user_id")
  
  // Organization Support (if owned by org, not individual user)
  organizationId String? @map("organization_id")

  name   String
  type   GatewayType
  status GatewayStatus @default(DISCONNECTED)

  // Encrypted credentials (AES-256-GCM)
  credentialsEnc String @map("credentials_enc") @db.Text
  
  // Provider-specific configuration
  config Json @default("{}")

  // Provider-specific metadata (bot info, AI provider details, etc.)
  // Persisted on connect so it survives server restarts
  metadata Json @default("{}")

  // Bot mode: "plugin" (single standalone plugin) or "workflow" (plugin pipeline)
  mode   String @default("plugin") @map("mode")

  // Connection tracking
  lastConnectedAt DateTime? @map("last_connected_at")
  lastErrorAt     DateTime? @map("last_error_at")
  lastError       String?   @map("last_error")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflows     Workflow[]
  workflowSteps WorkflowStep[]
  aiUsage       AIUsage[]
  userPlugins   UserPlugin[]
  gatewayChats  GatewayChat[]
  gatewayMetrics GatewayMetric[]

  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@map("gateways")
}

// ===========================================
// Gateway Chat Tracking (Phase 7)
// Tracks which Telegram chats the bot has been added to / removed from
// ===========================================
model GatewayChat {
  id          String    @id @default(cuid())
  gatewayId   String    @map("gateway_id")

  // Telegram chat info
  chatId      BigInt    @map("chat_id")        // Telegram chat ID (can be negative for groups)
  chatType    String    @map("chat_type")      // "private", "group", "supergroup", "channel"
  chatTitle   String?   @map("chat_title")     // Chat/group/channel title
  chatUsername String?  @map("chat_username")  // @username if public
  memberCount Int?      @map("member_count")   // Approximate member count

  // Status tracking
  isActive    Boolean   @default(true) @map("is_active")
  joinedAt    DateTime  @default(now()) @map("joined_at")
  leftAt      DateTime? @map("left_at")

  // Bot status in this chat
  botStatus   String    @default("member") @map("bot_status") // "member", "administrator", "kicked", "left"

  // Timestamps
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  gateway     Gateway   @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@unique([gatewayId, chatId])
  @@index([gatewayId, isActive])
  @@index([chatType])
  @@map("gateway_chats")
}

// ===========================================
// Gateway Metrics (Phase 8)
// Tracks action execution counts per gateway for analytics dashboards
// ===========================================
model GatewayMetric {
  id          String    @id @default(cuid())
  gatewayId   String    @map("gateway_id")

  // Action tracking
  action      String                            // e.g. "sendMessage", "getMe", "text-generation"
  
  // Counters
  successCount Int      @default(0) @map("success_count")
  errorCount   Int      @default(0) @map("error_count")
  
  // Performance
  totalDurationMs BigInt @default(0) @map("total_duration_ms") // Sum of all durations for avg calc

  // Period bucketing — one row per gateway+action+period
  period      String                            // "2026-02-09" (daily) or "2026-02-09T08" (hourly)

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  gateway     Gateway   @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@unique([gatewayId, action, period])
  @@index([gatewayId, period])
  @@index([action])
  @@index([createdAt])
  @@map("gateway_metrics")
}

// ===========================================
// Audit Log Model (Phase 1.5: Architecture)
// ===========================================
model AuditLog {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  organizationId String?  @map("organization_id")
  
  // Action details
  action         String   // 'gateway.create', 'plugin.install', 'user.login'
  resource       String   // 'gateway', 'plugin', 'user'
  resourceId     String?  @map("resource_id")
  
  // Additional context (no secrets!)
  metadata       Json?
  
  // Request info
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  
  // Result
  status         String   @default("success") // 'success', 'failure'
  
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===========================================
// Credit System Models (Phase 1.5: Architecture)
// ===========================================

/**
 * CreditWallet - Universal credit storage
 * 
 * Can belong to EITHER a user OR an organization (mutually exclusive).
 * This enables:
 * - Personal credits for individual users
 * - Shared organization credits for team members
 * - Future: Department-level budgets
 * 
 * Credit Resolution Order:
 * 1. If user is in org with shared credits → use org wallet
 * 2. Else → use personal wallet
 */
model CreditWallet {
  id              String   @id @default(cuid())
  
  // Owner - exactly one must be set (user XOR organization)
  userId          String?  @unique @map("user_id")
  organizationId  String?  @unique @map("organization_id")
  
  // Balance
  balance         Int      @default(0)   // Current credit balance (whole credits only)
  lifetime        Int      @default(0)   // Total credits ever added (purchases + grants)
  pendingCredits  Float    @default(0)   @map("pending_credits") // Accumulated fractional credits
  
  // Monthly allocation from plan (resets each billing period)
  monthlyAllocation Int    @default(0)   @map("monthly_allocation")
  monthlyUsed       Int    @default(0)   @map("monthly_used")
  allocationResetAt DateTime? @map("allocation_reset_at")
  
  // Daily credit claims (FREE/STARTER = daily, PRO+ = monthly auto-grant)
  lastClaimedAt       DateTime?  @map("last_claimed_at")
  monthlyClaimedTotal Int        @default(0)  @map("monthly_claimed_total")
  
  // Settings (auto-topup, notifications, etc.)
  settings        Json     @default("{}")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions    CreditTransaction[]

  @@map("credit_wallets")
}

model CreditTransaction {
  id              String   @id @default(cuid())
  
  // Wallet reference
  creditWalletId  String?  @map("credit_wallet_id")
  
  type            String   // 'purchase', 'usage', 'refund', 'bonus', 'grant', 'allocation'
  amount          Int      // Positive = credit, Negative = debit
  balanceAfter    Int      @map("balance_after")
  
  description     String
  metadata        Json?    // { stripeId?, aiProvider?, model?, itemId?, walletType? }
  
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  creditWallet    CreditWallet?  @relation(fields: [creditWalletId], references: [id], onDelete: Cascade)

  @@index([creditWalletId])
  @@index([type])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ===========================================
// Plugin Models (Phase 3: Plugin System)
// ===========================================

// Plugin definitions (system-defined for V1)
model Plugin {
  id            String        @id @default(cuid())
  slug          String        @unique  // "analytics", "welcome", "auto-reply"
  name          String
  description   String        @db.Text
  version       String        @default("1.0.0")
  
  // Requirements - which gateway types this plugin needs
  requiredGateways GatewayType[]
  
  // Configuration schema (JSON Schema format for validation)
  configSchema  Json          @default("{}")
  
  // Metadata for UI
  icon          String?       // Icon name or URL
  category      String        @default("general")  // "general", "analytics", "messaging", "automation"
  tags          String[]      @default([])         // Discovery tags: "sport", "blog", "ecommerce"
  isBuiltin     Boolean       @default(true)       // Built-in vs marketplace (V2)
  
  // Catalog template code for first-time installs to workspace containers
  // This is NOT user-specific code — the container filesystem is the source of truth for user code
  codeBundle    String?       @db.Text @map("code_bundle")
  
  // Authorship and visibility
  authorId      String?       @map("author_id")    // userId of creator (null for SYSTEM)
  authorType    PluginAuthorType @default(SYSTEM)   @map("author_type")
  isPublic      Boolean       @default(false)      @map("is_public")  // Marketplace visibility
  
  // Input/Output schemas for workflow integration (Phase 5+)
  inputSchema   Json?         @map("input_schema")   // What plugin accepts
  outputSchema  Json?         @map("output_schema")  // What plugin outputs

  // Event routing & conflict detection
  // eventTypes: which events this plugin handles (e.g. ["telegram.message", "telegram.callback"])
  eventTypes    String[]      @default([])           @map("event_types")
  // eventRole: "responder" (sends replies, exclusive), "observer" (read-only, unlimited)
  eventRole     String        @default("responder")  @map("event_role")
  // conflictsWith: slugs of plugins that cannot coexist on the same gateway
  conflictsWith String[]      @default([])           @map("conflicts_with")
  
  // Status
  isActive      Boolean       @default(true)  @map("is_active")
  
  // Timestamps
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  
  // Relations
  userPlugins   UserPlugin[]
  workflowSteps WorkflowStep[]
  
  @@index([slug])
  @@index([isActive])
  @@index([category])
  @@map("plugins")
}

// User/Organization installed plugins
model UserPlugin {
  id            String        @id @default(cuid())
  userId        String        @map("user_id")
  pluginId      String        @map("plugin_id")
  
  // Organization Support (same pattern as Gateway)
  organizationId String?      @map("organization_id")
  
  // User's configuration for this plugin (validated against Plugin.configSchema)
  config        Json          @default("{}")
  
  // Gateway binding - which gateway this plugin uses (if any)
  gatewayId     String?       @map("gateway_id")
  
  // Workspace entry file path (relative to workspace root, e.g. "plugins/my-bot.js" or "plugins/my-bot/index.js")
  entryFile     String?       @map("entry_file") @db.VarChar(500)
  
  // Storage quota for local KV store in MB (0 = unlimited, default 50)
  storageQuotaMb Int          @default(50) @map("storage_quota_mb")
  
  // Status
  isEnabled     Boolean       @default(true) @map("is_enabled")
  
  // Execution stats
  executionCount Int          @default(0) @map("execution_count")
  lastExecutedAt DateTime?    @map("last_executed_at")
  lastError      String?      @map("last_error")
  
  // Timestamps
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  
  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plugin        Plugin        @relation(fields: [pluginId], references: [id])
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  gateway       Gateway?      @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  aiUsages      AIUsage[]
  
  // Unique per user+plugin+gateway (allows same plugin on multiple gateways/bots)
  @@unique([userId, pluginId, organizationId, gatewayId])
  @@index([userId])
  @@index([pluginId])
  @@index([organizationId])
  @@index([gatewayId])
  @@index([isEnabled])
  @@map("user_plugins")
}

// ===========================================
// WORKFLOW MODELS (V2 Foundation - Phase 3)
// ===========================================

// Trigger types for workflows
enum WorkflowTriggerType {
  BOT_MESSAGE         // On incoming message to bound gateway (any platform)
  TELEGRAM_MESSAGE    // @deprecated — use BOT_MESSAGE (kept for migration compat)
  TELEGRAM_CALLBACK   // On callback button press
  DISCORD_MESSAGE     // @deprecated — use BOT_MESSAGE (kept for migration compat)
  DISCORD_COMMAND     // On Discord slash command / interaction
  SLACK_MESSAGE       // @deprecated — use BOT_MESSAGE (kept for migration compat)
  SLACK_COMMAND       // On Slack slash command / interaction
  WHATSAPP_MESSAGE    // @deprecated — use BOT_MESSAGE (kept for migration compat)
  SCHEDULE            // Cron-based trigger
  WEBHOOK             // External HTTP trigger
  MANUAL              // User-triggered
}

// Workflow status
enum WorkflowStatus {
  DRAFT               // Being edited
  ACTIVE              // Running
  PAUSED              // Temporarily disabled
  ARCHIVED            // Soft deleted
}

// Workflow scope (determines visibility and access)
enum WorkflowScope {
  USER                // Personal workspace OR employee personal in org
  DEPARTMENT          // Shared within department (org only)
  ORGANIZATION        // Company-wide automation (org only)
}

// Workflow definition (user-created automation chain)
model Workflow {
  id              String              @id @default(cuid())
  userId          String              @map("user_id")
  organizationId  String?             @map("organization_id")
  departmentId    String?             @map("department_id")  // For DEPARTMENT scope
  
  // Scope determines visibility and access
  // - USER scope: If organizationId=NULL, personal workspace workflow
  //               If organizationId!=NULL, employee personal workflow in org
  // - DEPARTMENT: Requires departmentId, shared within department  
  // - ORGANIZATION: Shared across entire organization
  scope           WorkflowScope       @default(USER)
  
  // Basic info
  name            String
  description     String?
  slug            String              // User-friendly URL slug
  
  // Trigger configuration
  triggerType     WorkflowTriggerType
  triggerConfig   Json                @default("{}")  // Type-specific settings
  
  // Bound gateway (for telegram/ai triggers)
  gatewayId       String?             @map("gateway_id")
  
  // Status
  status          WorkflowStatus      @default(DRAFT)
  isEnabled       Boolean             @default(false) @map("is_enabled")
  
  // Execution stats
  executionCount  Int                 @default(0) @map("execution_count")
  lastExecutedAt  DateTime?           @map("last_executed_at")
  lastError       String?             @map("last_error")
  
  // Timestamps
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  
  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  gateway         Gateway?            @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  department      Department?         @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  steps           WorkflowStep[]
  runs            WorkflowRun[]
  
  @@unique([userId, organizationId, slug])
  @@index([userId])
  @@index([organizationId])
  @@index([departmentId])
  @@index([scope])
  @@index([status])
  @@index([isEnabled])
  @@index([userId, gatewayId, triggerType, status, isEnabled])
  @@map("workflows")
}

// Individual step in a workflow chain
model WorkflowStep {
  id              String    @id @default(cuid())
  workflowId      String    @map("workflow_id")
  
  // Step position
  order           Int       // Execution order (0, 1, 2...)
  name            String?   // Optional label
  
  // Plugin to execute
  pluginId        String    @map("plugin_id")
  
  // Step configuration
  // How to map trigger/previous step data to this plugin's input
  inputMapping    Json      @default("{}")  // { "text": "{{trigger.message.text}}" }
  
  // Static config for the plugin
  config          Json      @default("{}")
  
  // Gateway override (use specific gateway instead of workflow default)
  gatewayId       String?   @map("gateway_id")
  
  // Conditional execution (optional)
  condition       Json?     // { "if": "{{prev.sentiment}} == 'negative'" }
  
  // Error handling
  onError         String    @default("stop")  // "stop", "continue", "retry"
  maxRetries      Int       @default(0)       @map("max_retries")
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  plugin          Plugin    @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  gateway         Gateway?  @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  
  @@unique([workflowId, order])
  @@index([workflowId])
  @@index([pluginId])
  @@map("workflow_steps")
}

// Workflow execution history
model WorkflowRun {
  id              String    @id @default(cuid())
  workflowId      String    @map("workflow_id")
  
  // Trigger info
  triggeredBy     String    // "telegram_message", "schedule", "manual", etc.
  triggerData     Json?     @map("trigger_data")  // Original trigger payload
  
  // Execution status
  status          String    @default("running")  // running, completed, failed, cancelled
  
  // Results
  output          Json?     // Final output
  error           String?   // Error message if failed
  failedStepOrder Int?      @map("failed_step_order")  // Which step failed
  
  // Performance
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  durationMs      Int?      @map("duration_ms")
  
  // Relations
  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepRuns        WorkflowStepRun[]
  
  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
  @@map("workflow_runs")
}

// Individual step execution in a run
model WorkflowStepRun {
  id              String      @id @default(cuid())
  runId           String      @map("run_id")
  stepOrder       Int         @map("step_order")
  
  // Execution
  status          String      @default("pending")  // pending, running, completed, failed, skipped
  input           Json?       // Actual input after mapping
  output          Json?       // Plugin output
  error           String?
  
  // Performance
  startedAt       DateTime?   @map("started_at")
  completedAt     DateTime?   @map("completed_at")
  durationMs      Int?        @map("duration_ms")
  
  // Relations
  run             WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  
  @@unique([runId, stepOrder])
  @@index([runId])
  @@map("workflow_step_runs")
}

// ===========================================
// AI Usage Tracking (Phase: 2Bot AI)
// Unified tracking for both BYOK and 2Bot AI
// ===========================================
model AIUsage {
  id              String    @id @default(cuid())
  
  // Owner
  userId          String    @map("user_id")
  organizationId  String?   @map("organization_id")
  departmentId    String?   @map("department_id")  // Track dept for budget enforcement
  gatewayId       String?   @map("gateway_id")
  userPluginId    String?   @map("user_plugin_id") // Track which plugin made this AI call
  
  // What was used - using universal capability naming
  capability      String    @map("capability") // "text-generation", "image-generation", "speech-synthesis", "speech-recognition", "text-embedding", "image-understanding"
  model           String    // "gpt-4o-mini", "dall-e-3", "whisper", etc.
  
  // Source - determines if credits apply
  source          String    // "byok" = user's key (no credits), "2bot" = platform key (credits)
  
  // Provider - which AI provider handled the request
  provider        String?   @map("provider") // "openai", "anthropic", "google", "together", "fireworks", "openrouter"
  
  // Feature - which platform feature triggered this usage
  feature         String?   @map("feature") // "chat", "cursor", "plugin-ipc", "api" — null for legacy rows
  
  // Raw metrics - store ALL for analytics (nullable based on capability type)
  inputTokens     Int?      @map("input_tokens")      // Chat/embedding input
  outputTokens    Int?      @map("output_tokens")     // Chat output
  totalTokens     Int?      @map("total_tokens")      // Chat/embedding total
  imageCount      Int?      @map("image_count")       // Image generation
  characterCount  Int?      @map("character_count")   // TTS character count
  audioSeconds    Int?      @map("audio_seconds")     // STT audio duration
  
  // Credits (only populated for source="2bot")
  creditsUsed     Float     @default(0) @map("credits_used") // Precise fractional credits
  
  // Billing period for aggregation
  billingPeriod   String    @map("billing_period")    // "2026-01" format
  
  // Request metadata (optional)
  requestId       String?   @map("request_id")        // For debugging
  durationMs      Int?      @map("duration_ms")       // Request latency
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  gateway         Gateway?  @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  userPlugin      UserPlugin? @relation(fields: [userPluginId], references: [id], onDelete: SetNull)
  
  @@index([userId, billingPeriod])
  @@index([organizationId, billingPeriod])
  @@index([departmentId, billingPeriod])
  @@index([gatewayId, createdAt])
  @@index([userPluginId, billingPeriod])
  @@index([source, billingPeriod])
  @@index([capability, createdAt])
  @@index([feature, billingPeriod])
  @@index([provider, billingPeriod])
  @@map("ai_usage")
}

// ===========================================
// Credit Rates (Phase: 2Bot AI)
// Configurable credit costs per AI capability/model
// ===========================================
model CreditRate {
  id              String    @id @default(cuid())
  
  // What this rate applies to - using universal capability naming
  capability      String    @map("capability") // "text-generation", "image-generation", etc.
  model           String    // "gpt-4o-mini", "dall-e-3", "whisper", etc.
  
  // Credit rates (only one applies based on capability type)
  creditsPerInputToken   Float?   @map("credits_per_input_token")   // Chat input (per token)
  creditsPerOutputToken  Float?   @map("credits_per_output_token")  // Chat output (per token)
  creditsPerImage        Float?   @map("credits_per_image")         // Image generation
  creditsPerChar         Float?   @map("credits_per_char")          // TTS (per character)
  creditsPerMinute       Float?   @map("credits_per_minute")        // STT
  
  // Your actual cost (for margin tracking - admin only)
  yourCostPer1kInput     Decimal? @map("your_cost_per_1k_input") @db.Decimal(10, 6)
  yourCostPer1kOutput    Decimal? @map("your_cost_per_1k_output") @db.Decimal(10, 6)
  yourCostPerUnit        Decimal? @map("your_cost_per_unit") @db.Decimal(10, 6)
  
  // Status
  isActive        Boolean   @default(true) @map("is_active")
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@unique([capability, model])
  @@index([isActive])
  @@map("credit_rates")
}

// ===========================================
// Knowledge Base Article (Phase 7: Support)
// ===========================================
model KBArticle {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  content         String    @db.Text    // Markdown content
  excerpt         String?               // Short summary for list view
  category        String                // getting_started, gateways, plugins, billing, troubleshooting

  // Search & Discovery
  tags            String[]              // Array of tags for filtering
  viewCount       Int       @default(0) @map("view_count")
  helpfulCount    Int       @default(0) @map("helpful_count")
  notHelpfulCount Int       @default(0) @map("not_helpful_count")

  // Status
  isPublished     Boolean   @default(false) @map("is_published")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  publishedAt     DateTime? @map("published_at")

  // Author (support/admin user)
  authorId        String    @map("author_id")
  author          User      @relation("KBArticleAuthor", fields: [authorId], references: [id])

  @@index([slug])
  @@index([category])
  @@index([isPublished])
  @@index([viewCount])
  @@map("kb_articles")
}

// ===========================================
// Support Ticket (Phase 7: Support)
// ===========================================
model SupportTicket {
  id              String    @id @default(cuid())
  ticketNumber    String    @unique @map("ticket_number") // TICKET-0001
  userId          String    @map("user_id")

  // Ticket Info
  type            String    // bug, question, billing, feature_request, other
  category        String    // gateway, plugin, billing, account, other
  severity        String    @default("medium") // low, medium, high, critical
  title           String
  description     String    @db.Text

  // Auto-captured Context (JSON)
  contextData     Json      @default("{}") @map("context_data")
  // Structure: { url, browser, os, screenSize, recentActions, gatewayStatus, errorLogs }

  // AI Chat History (JSON) - conversation that led to ticket creation
  aiChatHistory   Json      @default("[]") @map("ai_chat_history")

  // Status & Assignment
  status          String    @default("open") // open, in_progress, waiting_user, resolved, closed
  priority        Int       @default(0)      // For queue ordering (higher = more urgent)
  assignedToId    String?   @map("assigned_to_id")

  // Resolution
  resolution      String?   @db.Text
  resolvedAt      DateTime? @map("resolved_at")

  // Linked Resources
  relatedArticleId String? @map("related_article_id")

  // SLA tracking (for future premium support tiers)
  firstResponseAt  DateTime? @map("first_response_at")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation("UserTickets", fields: [userId], references: [id])
  assignedTo      User?     @relation("AssignedTickets", fields: [assignedToId], references: [id])
  messages        TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([assignedToId])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@map("support_tickets")
}

// ===========================================
// Ticket Message (Conversation Thread)
// ===========================================
model TicketMessage {
  id              String    @id @default(cuid())
  ticketId        String    @map("ticket_id")
  senderId        String    @map("sender_id")

  content         String    @db.Text
  isInternal      Boolean   @default(false) @map("is_internal") // Internal notes (support only)

  createdAt       DateTime  @default(now()) @map("created_at")

  // Relations
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender          User          @relation("TicketMessageSender", fields: [senderId], references: [id])

  @@index([ticketId])
  @@index([senderId])
  @@map("ticket_messages")
}

// ===========================================
// Quick Issue Templates (Phase 7: Support)
// ===========================================
model QuickIssue {
  id                String    @id @default(cuid())
  title             String    // "Gateway not connecting"
  description       String?   // Brief help text

  // Auto-fill values
  suggestedType     String    @map("suggested_type")     // bug, question, etc.
  suggestedCategory String    @map("suggested_category") // gateway, billing, etc.

  // Link to KB Article (if exists)
  articleSlug       String?   @map("article_slug")

  // Usage tracking
  useCount          Int       @default(0) @map("use_count")

  // Display
  icon              String?   // Emoji or icon name
  sortOrder         Int       @default(0) @map("sort_order")
  isActive          Boolean   @default(true) @map("is_active")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@index([sortOrder])
  @@map("quick_issues")
}

// ===========================================
// Workspace Container (Phase 13: Workspace System)
// Tracks Docker containers for user/org workspaces
// ===========================================
// 
// PERSONAL workspace: userId set, organizationId null
//   → User pays via personal plan/addons
//   → Resources from user's workspaceRamMb/CpuCores/StorageMb
//
// ORGANIZATION workspace: both userId and organizationId set
//   → userId = member who owns this container within the org
//   → Resources drawn from org's workspacePool
//   → Subject to DeptAllocation / MemberAllocation limits
//
// An org can have MULTIPLE containers (one per member who needs it)
// A user can have ONE personal container + ONE per org they belong to
// ===========================================
model WorkspaceContainer {
  id                String           @id @default(cuid())
  
  // Owner references
  userId            String           @map("user_id")
  organizationId    String?          @map("organization_id")
  
  // Ownership type (determines billing & resource source)
  ownerType         WorkspaceOwnerType @default(PERSONAL) @map("owner_type")
  
  // Docker container info
  containerId       String?          @map("container_id")         // Docker container ID (null before creation)
  containerName     String           @unique @map("container_name") // Unique name: "ws-{userId}" or "ws-{orgSlug}-{userId}"
  imageName         String           @default("2bot-workspace:latest") @map("image_name")
  
  // Status
  status            ContainerStatus  @default(CREATING)
  errorMessage      String?          @map("error_message")        // Last error details
  
  // Allocated resources (snapshot at creation, may differ from plan if resized)
  ramMb             Int              @map("ram_mb")               // Allocated RAM in MB
  cpuCores          Float            @map("cpu_cores")            // Allocated CPU cores
  storageMb         Int              @map("storage_mb")           // Allocated storage in MB
  
  // Runtime info
  ipAddress         String?          @map("ip_address")           // Internal container IP
  bridgePort        Int?             @map("bridge_port")          // Bridge agent WebSocket port
  bridgeAuthToken   String?          @map("bridge_auth_token")    // Encrypted auth token for bridge reconnection
  volumePath        String?          @map("volume_path")          // Host path for persistent volume
  
  // Health monitoring
  lastHealthCheck   DateTime?        @map("last_health_check")
  healthCheckFails  Int              @default(0) @map("health_check_fails")
  autoRestart       Boolean          @default(true) @map("auto_restart")
  maxRestarts       Int              @default(5) @map("max_restarts")
  restartCount      Int              @default(0) @map("restart_count")
  
  // Lifecycle timestamps
  startedAt         DateTime?        @map("started_at")
  stoppedAt         DateTime?        @map("stopped_at")
  lastActivityAt    DateTime?        @map("last_activity_at")     // For auto-stop idle containers
  
  // Auto-stop settings (save resources when idle)
  autoStopMinutes   Int?             @map("auto_stop_minutes")    // null = never auto-stop
  
  // Webhook routing (Phase A: direct container webhook delivery)
  webhookRoutingActive Boolean       @default(false) @map("webhook_routing_active")
  
  // Timestamps
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  
  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization      Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  files             WorkspaceFile[]
  logs              WorkspaceLog[]
  egressLogs        WorkspaceEgressLog[]
  
  // Personal: one container per user (no org)
  // Org: one container per user per org
  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([ownerType])
  @@index([containerId])
  @@map("workspace_containers")
}

// ===========================================
// Workspace File (Phase 13: Workspace System)
// Metadata tracking for files in user workspaces
// ===========================================
// 
// NOTE: File CONTENT lives inside the Docker container volume.
// This model tracks metadata for:
//   - Search / discovery across workspaces (admin)
//   - Plugin file tracking (which files are plugins)
//   - Storage quota enforcement
//   - File history / audit trail
// ===========================================
model WorkspaceFile {
  id                String           @id @default(cuid())
  containerId       String           @map("container_id")
  
  // File info
  path              String                                        // Full path inside container: /workspace/plugins/bot.js
  name              String                                        // File/folder name: bot.js
  type              WorkspaceFileType @default(FILE)
  sizeBytes         Int              @default(0) @map("size_bytes")
  mimeType          String?          @map("mime_type")            // "application/javascript", "application/json"
  
  // Plugin tracking
  isPlugin          Boolean          @default(false) @map("is_plugin")  // Registered as a runnable plugin
  pluginStatus      String?          @map("plugin_status")              // "running", "stopped", "error" (null if not plugin)
  pluginPid         Int?             @map("plugin_pid")                 // Process ID when running
  
  // Source tracking
  source            String           @default("upload")                 // "upload", "ai-generated", "github-import", "plugin-store", "manual"
  sourceUrl         String?          @map("source_url")                 // GitHub URL if imported
  
  // Timestamps
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  
  // Relations
  container         WorkspaceContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)
  
  @@unique([containerId, path])
  @@index([containerId])
  @@index([isPlugin])
  @@index([source])
  @@map("workspace_files")
}

// ===========================================
// Workspace Log (Phase 13: Workspace System)
// Execution and system logs from containers
// ===========================================
model WorkspaceLog {
  id                String           @id @default(cuid())
  containerId       String           @map("container_id")
  
  // Log entry
  level             String           @default("info")             // "debug", "info", "warn", "error", "fatal"
  source            String           @default("system")           // "system", "bridge", "plugin", "terminal", "git", "npm"
  message           String           @db.Text
  
  // Optional structured metadata
  metadata          Json?                                         // { pluginFile, pid, exitCode, command, etc. }
  
  // Source plugin (if from a plugin)
  pluginFile        String?          @map("plugin_file")          // "plugins/bot.js"
  
  // Timestamps
  createdAt         DateTime         @default(now()) @map("created_at")
  
  // Relations
  container         WorkspaceContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)
  
  @@index([containerId, createdAt])
  @@index([containerId, level])
  @@index([containerId, source])
  @@index([createdAt])
  @@map("workspace_logs")
}

// ===========================================
// Workspace Audit Log (Phase 13: Workspace System)
// Records all lifecycle actions for compliance and debugging
// ===========================================
model WorkspaceAuditLog {
  id                String           @id @default(cuid())
  
  // Who performed the action
  userId            String?          @map("user_id")              // null for system-initiated actions (auto-stop, auto-restart)
  
  // Which container was affected
  containerId       String           @map("container_id")         // Workspace container DB ID
  containerName     String?          @map("container_name")       // Snapshot of container name at time of action
  
  // What happened
  action            String                                        // CREATE, START, STOP, DESTROY, FORCE_STOP, AUTO_STOP, AUTO_RESTART, ERROR
  
  // Outcome
  success           Boolean          @default(true)
  errorMessage      String?          @map("error_message")
  
  // Optional structured metadata (resources, reason, etc.)
  metadata          Json?
  
  // Request context
  ipAddress         String?          @map("ip_address")
  userAgent         String?          @map("user_agent")
  
  // Timestamp
  createdAt         DateTime         @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([containerId])
  @@index([action])
  @@index([createdAt])
  @@map("workspace_audit_logs")
}

// ===========================================
// Workspace Metrics (Phase 13: Workspace System)
// Periodic snapshots of container resource usage for time-series analysis
// ===========================================
model WorkspaceMetric {
  id                String           @id @default(cuid())
  
  containerId       String           @map("container_id")         // Workspace container DB ID
  
  // Resource usage snapshot
  memoryUsedMb      Float            @map("memory_used_mb")
  memoryPercent     Float            @map("memory_percent")       // 0-100
  cpuPercent        Float            @map("cpu_percent")          // 0-100
  diskUsedMb        Float            @map("disk_used_mb")
  diskPercent       Float            @map("disk_percent")         // 0-100
  
  // Process info
  runningPlugins    Int              @default(0) @map("running_plugins")
  
  // Timestamp
  createdAt         DateTime         @default(now()) @map("created_at")
  
  @@index([containerId, createdAt])
  @@index([createdAt])
  @@map("workspace_metrics")
}

// ===========================================
// Workspace Egress Log (Phase 13.2: Egress Proxy)
// Records outbound network requests from workspace containers
// Parsed from Squid proxy access.log for per-user attribution
// ===========================================
model WorkspaceEgressLog {
  id                String           @id @default(cuid())
  containerId       String           @map("container_id")         // Workspace container DB ID
  
  // Request info (parsed from Squid access.log or webhook delivery)
  timestamp         DateTime                                      // When the request was made
  domain            String                                        // "api.telegram.org", "github.com"
  url               String?          @db.Text                     // Full URL (HTTP) or CONNECT domain (HTTPS)
  method            String           @default("CONNECT")          // GET, POST, CONNECT, etc.
  httpStatus        Int              @map("http_status")          // 200, 403, 407, 503, etc.
  squidStatus       String           @map("squid_status")         // TCP_TUNNEL, TCP_DENIED, etc.  (empty for inbound)
  bytesTransferred  Int              @default(0) @map("bytes_transferred")
  elapsedMs         Int              @default(0) @map("elapsed_ms")  // Response time in ms
  
  // Classification
  action            String           @default("ALLOWED")          // "ALLOWED", "BLOCKED", "RATE_LIMITED"
  direction         String           @default("OUTBOUND")         // "OUTBOUND" or "INBOUND"
  
  // Inbound-specific fields
  sourceType        String?          @map("source_type")          // "telegram", "custom", etc.
  pluginFile        String?          @map("plugin_file")          // Which plugin(s) received this webhook
  
  // Timestamps
  createdAt         DateTime         @default(now()) @map("created_at")
  
  // Relations
  container         WorkspaceContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)
  
  @@index([containerId, timestamp])
  @@index([containerId, domain])
  @@index([domain, timestamp])
  @@index([action, timestamp])
  @@index([timestamp])
  @@index([direction, containerId, timestamp])
  @@map("workspace_egress_logs")
}

// ===========================================
// Custom Gateway — REMOVED (unified into Gateway model)
// ===========================================
// Custom gateways now live in the `gateways` table with type = CUSTOM_GATEWAY.
// They use the same Gateway model, UserPlugin.gatewayId relation, credentialsEnc
// encryption, and routeEventToPlugins() pipeline as Telegram bots.
// The old `plugin_webhooks` table has been dropped.

// ===========================================
// Workspace Allowed Domains (User-controlled egress allowlist)
// ===========================================
// Users can request additional domains beyond the system-wide allowlist.
// When approved (or auto-approved), these domains are injected into the
// Squid proxy's dynamic ACL and take effect after a config reload.

model WorkspaceAllowedDomain {
  id              String    @id @default(cuid())

  // Owner — domains are per-user (apply to their workspace container)
  userId          String    @map("user_id")

  // The domain pattern (e.g. ".example.com" for example.com + subdomains)
  domain          String    // Stored with leading dot for subdomain matching

  // Approval status
  status          DomainAllowStatus @default(APPROVED)

  // Justification from user (why they need this domain)
  reason          String?

  // Consent: user accepted responsibility for external traffic
  consentAccepted Boolean   @default(false) @map("consent_accepted")
  consentAt       DateTime? @map("consent_at")

  // Admin review (optional — auto-approved by default)
  reviewedBy      String?   @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewNote      String?   @map("review_note")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId])
  @@index([status])
  @@map("workspace_allowed_domains")
}

enum DomainAllowStatus {
  PENDING   // Awaiting admin approval (if admin-review mode enabled)
  APPROVED  // Active — domain is in the proxy allowlist
  REJECTED  // Admin rejected the request
  REVOKED   // Was approved but later revoked
}

// ===========================================
// Admin-Blocked Domains (Global Blacklist)
// ===========================================
// Domains that are always blocked regardless of user approval.
// Admin-blocked domains override any user allowlist entries.

model AdminBlockedDomain {
  id          String   @id @default(cuid())

  // The blocked domain pattern (e.g. ".malware.com")
  domain      String   @unique

  // Why this domain is blocked
  reason      String?

  // Who added it
  createdBy   String   @map("created_by")

  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  admin       User     @relation("AdminBlockedDomains", fields: [createdBy], references: [id])

  @@index([domain])
  @@map("admin_blocked_domains")
}

// ===========================================
// Support AI Cost Tracking (Phase 7: Support)
// ===========================================
model SupportAICost {
  id              String    @id @default(cuid())

  // Who triggered the cost
  userId          String?   @map("user_id")  // User who asked (null = anonymous)

  // AI usage details
  model           String    // Provider model ID used (e.g. "claude-3-5-haiku-20241022")
  provider        String    // "openai", "anthropic", "together"
  inputTokens     Int       @map("input_tokens")
  outputTokens    Int       @map("output_tokens")

  // Cost tracking (real API cost, NO margin)
  apiCostUsd      Float     @map("api_cost_usd")   // Actual API cost in USD
  creditsCharged  Float     @map("credits_charged") // Credits that would be charged (with margin)

  // Billing period for aggregation
  billingPeriod   String    @map("billing_period") // "2026-02" format

  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([billingPeriod])
  @@index([createdAt])
  @@index([userId])
  @@map("support_ai_costs")
}

// ===========================================
// AI Agent Session Tracking
// ===========================================

/**
 * AgentSession — Tracks the full lifecycle of an AI agent task.
 *
 * One user prompt → multiple AI iterations → multiple tool calls → final response.
 * Used for billing audit, usage history, debugging, and admin analytics.
 */
model AgentSession {
  id               String    @id @default(cuid())

  // Owner
  userId           String    @map("user_id")
  organizationId   String?   @map("organization_id")
  workspaceId      String    @map("workspace_id")

  // AI model used
  model            String

  // Session lifecycle
  status           String    @default("running")  // running, completed, max_iterations, max_credits, error, cancelled

  // Metrics
  iterationCount   Int       @default(0) @map("iteration_count")
  toolCallCount    Int       @default(0) @map("tool_call_count")
  totalCreditsUsed Float     @default(0) @map("total_credits_used")
  inputTokens      Int       @default(0) @map("input_tokens")
  outputTokens     Int       @default(0) @map("output_tokens")

  // Content
  prompt           String    @db.Text          // User's original prompt
  finalResponse    String?   @map("final_response") @db.Text  // AI's final text (on completion)
  error            String?   @db.Text          // Error message (on failure)

  // Duration
  durationMs       Int?      @map("duration_ms")

  // Timestamps
  startedAt        DateTime  @default(now()) @map("started_at")
  completedAt      DateTime? @map("completed_at")

  // Relations
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls        AgentToolCall[]

  @@index([userId, startedAt])
  @@index([organizationId, startedAt])
  @@index([workspaceId])
  @@index([status])
  @@index([startedAt])
  @@map("agent_sessions")
}

/**
 * AgentToolCall — Individual tool invocation within an agent session.
 *
 * Records what the AI asked to do, what happened, and how long it took.
 * Used for debugging, audit trail, and understanding agent behavior.
 */
model AgentToolCall {
  id             String    @id @default(cuid())

  // Parent session
  sessionId      String    @map("session_id")

  // Tool details
  toolName       String    @map("tool_name")     // e.g. "read_file", "run_command"
  toolCallId     String    @map("tool_call_id")   // AI provider's tool call ID
  input          Json                              // Tool arguments (JSON)
  output         String    @db.Text               // Tool execution output (truncated)
  isError        Boolean   @default(false) @map("is_error")

  // Performance
  durationMs     Int       @default(0) @map("duration_ms")

  // Ordering within the session
  sequence       Int       @default(0)            // 0-based order within session

  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  session        AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sequence])
  @@index([toolName])
  @@index([createdAt])
  @@map("agent_tool_calls")
}