# ============================================
# 2Bot Platform - Environment Variables Template
# ============================================
# This file documents ALL environment variables used in the project.
#
# File structure:
#   .env                 — Shared base config (DATABASE_URL, domain, LOG_LEVEL)
#   .env.local           — ALL secrets (JWT, Stripe, API keys) - GITIGNORED
#   .env.development     — Development URLs (dev-api.2bot.org) - GITIGNORED
#   .env.production      — Production URLs (api.2bot.org) - GITIGNORED
#
# Setup instructions:
#   1. Copy this file to .env.local
#   2. Fill in all secret values
#   3. Create .env.development and .env.production with appropriate URLs
#   4. Run: make dev (for development) or make start (for production)
# ============================================

# ============================================
# Environment Mode
# ============================================
NODE_ENV=development  # or 'production'

# ============================================
# Domain Configuration (goes in .env)
# ============================================
NEXT_PUBLIC_ROOT_DOMAIN=2bot.org
NEXT_PUBLIC_ENTERPRISE_CONTACT_EMAIL=enterprise@2bot.org
ADMIN_EMAIL=admin@2bot.org
LOG_LEVEL=info  # or 'debug', 'warn', 'error'

# ============================================
# Application URLs (goes in .env.development / .env.production)
# ============================================
# Development URLs (dev mode):
NEXT_PUBLIC_APP_URL=https://dev.2bot.org
NEXT_PUBLIC_DASHBOARD_URL=https://dev.2bot.org
NEXT_PUBLIC_API_URL=https://dev-api.2bot.org
NEXT_PUBLIC_ADMIN_URL=https://admin.2bot.org
NEXT_PUBLIC_SUPPORT_URL=https://support.2bot.org
NEXT_PUBLIC_DOCS_URL=https://docs.2bot.org
NEXT_PUBLIC_DEV_URL=https://dev.2bot.org
NEXT_PUBLIC_DEV_API_URL=https://dev-api.2bot.org

# Production URLs (prod mode):
# NEXT_PUBLIC_APP_URL=https://www.2bot.org
# NEXT_PUBLIC_DASHBOARD_URL=https://dash.2bot.org
# NEXT_PUBLIC_API_URL=https://api.2bot.org
# NEXT_PUBLIC_ADMIN_URL=https://admin.2bot.org
# NEXT_PUBLIC_SUPPORT_URL=https://support.2bot.org
# NEXT_PUBLIC_DOCS_URL=https://docs.2bot.org

# ============================================
# Database (PostgreSQL) - goes in .env and .env.local
# ============================================
# .env (for Prisma CLI):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/2bot_dev?schema=public

# .env.local (credentials):
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres  # CHANGE IN PRODUCTION: openssl rand -base64 32
POSTGRES_DB=2bot_dev

# Production example:
# POSTGRES_USER=2bot_prod
# POSTGRES_PASSWORD=<GENERATED_STRONG_PASSWORD>
# POSTGRES_DB=2bot_production
# DATABASE_URL=postgresql://2bot_prod:<PASSWORD>@postgres:5432/2bot_production

# ============================================
# Redis Cache - goes in .env.local
# ============================================
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=  # Optional - set if Redis has requirepass configured

# Production with password:
# REDIS_PASSWORD=<GENERATED_STRONG_PASSWORD>
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ============================================
# Authentication (JWT) - goes in .env.local
# ============================================
# ⚠️ CRITICAL: Generate strong secrets for production!
# Generate with: openssl rand -base64 64
JWT_SECRET=dev-jwt-secret-do-not-use-in-production-change-me
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-do-not-use-in-production-change-me

# ============================================
# Encryption - goes in .env.local
# ============================================
# ⚠️ CRITICAL: Never change this after encrypting data!
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ============================================
# Stripe Billing - goes in .env.local
# ============================================
# Test Mode (development):
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret

# User Plan Price IDs (create in Stripe Dashboard):
STRIPE_PRICE_STARTER=price_test_starter
STRIPE_PRICE_PRO=price_test_pro
STRIPE_PRICE_BUSINESS=price_test_business

# Organization Plan Price IDs (create in Stripe Dashboard):
STRIPE_ORG_GROWTH_PRICE_ID=price_test_org_growth
STRIPE_ORG_PRO_PRICE_ID=price_test_org_pro
STRIPE_ORG_BUSINESS_PRICE_ID=price_test_org_business

# Live Mode (production):
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_BUSINESS=price_...

# ============================================
# Email (Resend) - goes in .env.local
# ============================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=2Bot <noreply@2bot.org>
EMAIL_REPLY_TO=support@2bot.org

# Development:
# EMAIL_FROM=2Bot Dev <noreply@localhost>
# EMAIL_REPLY_TO=dev@localhost
# RESEND_API_KEY=  # Leave empty to disable emails in dev

# ============================================
# 2Bot AI Service (Platform Credits) - goes in .env.local
# ============================================
# These keys power 2Bot's built-in AI assistant (credits-based)
# Separate from user BYOK (Bring Your Own Key) gateways

# OpenAI - GPT-4o, GPT-4o-mini, DALL-E 3, TTS, Whisper
# Get from: https://platform.openai.com/api-keys
TWOBOT_OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic - Claude 4 Opus, Claude 4 Sonnet, Claude 3.5 Sonnet
# Get from: https://console.anthropic.com/settings/keys
TWOBOT_ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Together AI - DeepSeek, Llama, Qwen, FLUX, Imagen
# Get from: https://api.together.xyz/settings/api-keys
# TWOBOT_TOGETHER_API_KEY=your-together-key-here

# Fireworks AI - DeepSeek, FLUX
# Get from: https://fireworks.ai/account/api-keys
# TWOBOT_FIREWORKS_API_KEY=your-fireworks-key-here

# OpenRouter - Gemini, GPT-5, DeepSeek, 300+ models
# Get from: https://openrouter.ai/keys
# TWOBOT_OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Vertex AI (Google Cloud) — Gemini models + Imagen (COMING SOON)
# Requires a GCP project with Vertex AI API enabled
# TWOBOT_VERTEX_AI_PROJECT=your-gcp-project-id
# TWOBOT_VERTEX_AI_REGION=us-central1
# TWOBOT_VERTEX_AI_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ============================================
# Telegram (Optional) - goes in .env.local
# ============================================
# For testing Telegram gateway features
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================
# Cron Jobs Security - goes in .env.local
# ============================================
# Secret key for authenticating cron job endpoints
CRON_SECRET=your-cron-secret-here

# ============================================
# Sentry Error Tracking (Optional) - goes in .env.local
# ============================================
# Get from: https://sentry.io/settings/
# Leave empty to disable error tracking
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=2bot
SENTRY_PROJECT=2bot-platform

# Production:
# SENTRY_DSN=https://...@....ingest.sentry.io/...
# SENTRY_AUTH_TOKEN=sntrys_...

# ============================================
# Graceful Shutdown - goes in .env.local
# ============================================
# Time to wait for load balancer to drain connections (ms)
SHUTDOWN_DELAY_MS=5000

# Force exit timeout if graceful shutdown hangs (ms)
FORCE_SHUTDOWN_TIMEOUT_MS=30000

# ============================================
# AI Privacy Settings - goes in .env.local
# ============================================
AI_CACHE_ENABLED=true

# ============================================
# Feature Flags (Optional) - goes in .env.local
# ============================================
# Enable debug logging
# DEBUG=true

# Skip email verification for faster testing
# SKIP_EMAIL_VERIFICATION=true
