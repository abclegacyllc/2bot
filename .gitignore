# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-admin/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
server.log

# env files (all ignored except .env.example)
.env*
!.env.example

# SSL certificates (NEVER commit)
/ssl/
*.key
nginx/ssl/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client
/src/generated/prisma

# Archive folder (old/deprecated code)
/_archive_

# Database backups (NEVER commit)
*.sql
!prisma/migrations/**/*.sql

# Nginx generated route maps
nginx/gateway-routes.map

# Accidental psql output files
ql *

# IDE / editor tools
.qodo/
.idea/
*.swp
*.swo
*~

# Server logs and PID files
/tmp/2bot-logs/
