# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-admin/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
server.log

# env files (all ignored except .env.example)
.env*
!.env.example

# SSL certificates (NEVER commit)
/ssl/
*.key
nginx/ssl/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated client
/src/generated/prisma

# Archive folder (old/deprecated code)
/_archive_

# Database backups (NEVER commit)
/backups/
*.sql
*.sql.gz
!prisma/migrations/**/*.sql

# Nginx generated route maps
nginx/gateway-routes.map
nginx/apps-routes.map

# Accidental terminal command fragment files
ql *
= *
leep *
elect*
t p = *
# Stray single-letter / short artifact files left behind by mis-typed
# pipe / redirection commands (`> et`, `> t123"`, etc).
/et
/t123*
# One-off operational fix-up scripts that often hardcode prod IDs or
# decrypted secrets. Keep them locally if you need to re-run, but never
# check in. Prefer Prisma migrations or proper services for anything
# repeatable.
/scripts/fix-*.ts
/scripts/fix-*.js

# IDE / editor tools
.qodo/
.idea/
*.swp
*.swo
*~

# Server logs and PID files
/tmp/2bot-logs/
Vetex AI code review.txt
